# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/projectos"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/projectos"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ───────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-32-bytes-random-string-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ── OAuth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Storage ─────────────────────────────────────────────────────────────────────
AWS_S3_BUCKET="projectos-uploads"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-central-1"
# For local dev use MinIO:
S3_ENDPOINT="http://localhost:9000"

# ── Email ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@projectos.io"
# For local dev:
SMTP_HOST="localhost"
SMTP_PORT="1025"

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=""
PROMETHEUS_PORT="9090"

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
VITE_API_URL="http://localhost:3001"
